    <ExecuteAction Persistent="true" RunAt="Install">
      <Condition><![CDATA[("%WinSysDir32%\d3dx9_43.dll"=-1) OR ((%WOW64MODE%=true) AND ("%WinSysDir64%\d3dx9_43.dll"=-1))]]></Condition>
      <Exe SuppressWindow="true" DisplayText="Installing Microsoft DirectX 9.0c SDK">%SapSrcDir%\VE\DX9SDK\DXSETUP.exe</Exe>
      <Parameters>/SILENT</Parameters>
      <Wait TimeOut="120000">%ErrorLevel%=0</Wait>
