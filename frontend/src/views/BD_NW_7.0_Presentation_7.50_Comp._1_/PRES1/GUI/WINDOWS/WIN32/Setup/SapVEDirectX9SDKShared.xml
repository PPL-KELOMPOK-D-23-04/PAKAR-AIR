      <Src>%SapSrcDir%\VE\DX9SDK\Jun2010_D3DCompiler_43_x64.cab</Src>
      <Src>%SapSrcDir%\VE\DX9SDK\Jun2010_D3DCompiler_43_x86.cab</Src>
      <Src>%SapSrcDir%\VE\DX9SDK\Jun2010_d3dx9_43_x64.cab</Src>
      <Src>%SapSrcDir%\VE\DX9SDK\Jun2010_d3dx9_43_x86.cab</Src>
    </Action>
  </Component>
</SapSetup>