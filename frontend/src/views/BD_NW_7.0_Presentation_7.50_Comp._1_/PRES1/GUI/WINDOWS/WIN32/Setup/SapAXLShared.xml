		<Action RunAt="Install,Update" Type="Script">
			<Src><![CDATA[
NwEngine.Context.Log.Write "AXL Script: Change windows path to file:/// URL"
					strOrigPath = NwEngine.Variables.ResolveString("%SapAXLDestDir%\SAPExcelWorkbook.vsto")
					If NwEngine.Shell.FileExist(strOrigPath) Then
						NwEngine.Context.Log.Write "AXL Script: Original path: " & strOrigPath
						strNewPath = Replace(strOrigPath, "\", "/")
						strNewPath = "file:///" & strNewPath
						NwEngine.Context.Log.Write "AXL Script: New Path: " & strNewPath
						NwEngine.Variables.AppendDefaultValue "varSAPAXLURL", strNewPath
						NwEngine.Variables.Persistent("varSAPAXLURL") = vbFalse
					Else
						NwEngine.Context.Log.Write "AXL Script: File " & strOrigPath & " doesn't exist, seems to be an update with min_compliant_version incremented"
					End If
			]]></Src>
		</Action>
		<ExecuteAction RunAt="Update,Uninstall">
			<Condition>&quot;%varSAPAXLURL%&quot; &lt;&gt; &quot;&quot;</Condition>
			<Exe DisplayText="Deregistering SAPExcelWorkbook" SuppressWindow="true">%SapAXLVSTOInstallerPath%</Exe>
			<Parameters>/uninstall &quot;%varSAPAXLURL%&quot; /silent</Parameters>
			<NoWait/>
		</ExecuteAction>
