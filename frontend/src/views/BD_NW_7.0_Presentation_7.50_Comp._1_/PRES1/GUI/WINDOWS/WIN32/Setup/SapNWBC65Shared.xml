		<Action RunAt="Install" Type="Script">
			<Src><![CDATA[
szUNCPath =  NwEngine.Shell.GetUncPath( NwEngine.Variables.ResolveString ("%SAPSrcDir%") )
			If szUNCPath = "" Then
				szServerName = "localhost"
				NwEngine.Context.log.Write "Script: Current Installationsource is on local drive!"
			Else
				NwEngine.Context.log.Write "Script: Retrieving Servername from current Installationsource: " & szUNCPath
				iPos = Instr( 3, szUNCPath, "\", vbTextCompare )
				szServerName = Mid( szUNCPath, 3, iPos - 3 )
			End if
			NWEngine.Variables.InsertVariable "ServerName", szServerName
			NWEngine.Variables.Persistent("ServerName") = vbFalse
			]]></Src>
		</Action>
